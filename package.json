{
  "name": "tagging-schema-browser",
  "private": true,
  "homepage": "https://osmberlin.github.io/tagging-schema-browser/",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/osmberlin/tagging-schema-browser.git"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit -p tsconfig.app.json && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "lint": "oxlint --fix --fix-dangerously --deny-warnings -c oxlint.config.mjs .",
    "lint-check": "oxlint --deny-warnings -c oxlint.config.mjs .",
    "format": "oxfmt --write -c oxfmt.config.mjs .",
    "format-check": "oxfmt --check -c oxfmt.config.mjs .",
    "test": "vitest",
    "test-run": "vitest run",
    "check": "bun run type-check && bun run lint-check && bun run format-check && bun run test-run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@enzet/roentgen": "^0.16.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/lexend": "^5.2.11",
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-regular-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@headlessui/react": "^2.2.0",
    "@mapbox/maki": "^8.2.0",
    "@rapideditor/temaki": "^5.12.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-query": "^5.90.0",
    "@tanstack/react-router": "^1.94.0",
    "@tanstack/react-virtual": "^3.14.3",
    "itemsjs": "^2.4.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.0.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@playwright/test": "^1.58.2",
    "@rolldown/plugin-babel": "^0.2.0",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.2.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "browserslist": "^4.24.0",
    "browserslist-to-esbuild": "^2.1.1",
    "eslint-plugin-compat": "^7.0.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "oxlint-config-react-hooks-js": "^1.1.3",
    "oxlint-tsgolint": "^0.23.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.0.0",
    "typescript": "7.0.1-rc",
    "vite": "^8.0.0",
    "vitest": "^3.2.4"
  },
  "optionalDependencies": {
    "@typescript/typescript-darwin-arm64": "7.0.1-rc",
    "@typescript/typescript-linux-x64": "7.0.1-rc"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not op_mini all",
    "not kaios > 0"
  ]
}
